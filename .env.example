# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DATABASE_URL=postgres://koinoflow:koinoflow@db:5432/koinoflow

# Redis
REDIS_URL=redis://redis:6379/0

# OAuth (get from Google/GitHub developer console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MCP server (remote HTTP)
KOINOFLOW_API_URL=http://backend:8000/api/v1
# The MCP server's public URL (used for Protected Resource Metadata)
MCP_SERVER_URL=http://localhost:8001
# OAuth introspection credentials — the MCP server uses these to validate tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_INTROSPECT_CLIENT_ID=mcp-resource-server
MCP_INTROSPECT_CLIENT_SECRET=
# Signing secret for MCP approval tokens — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_APPROVAL_TOKEN_SECRET=

# Connectors — Atlassian / Confluence
# Register at developer.atlassian.com, add callback: http://localhost:8002/api/v1/connectors/confluence/callback
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Dedicated HMAC secret for Confluence webhook signature verification (must differ from client secret)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ATLASSIAN_WEBHOOK_SECRET=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_ENCRYPTION_KEY=
APP_BASE_URL=http://localhost:8002
INTERNAL_TASK_TOKEN=

# Cloud Tasks (production only — leave blank for local dev)
CLOUD_TASKS_PROJECT=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE=default
CLOUD_TASKS_SERVICE_URL=
CLOUD_TASKS_SERVICE_ACCOUNT=

# Capture AI extraction pipeline
# Smithery MCP registry key — get at https://smithery.ai (optional, enriches integration_needs)
SMITHERY_API_KEY=
# How long to cache Smithery registry results in Redis. Default: 86400 (24 h)
SMITHERY_CACHE_TTL_SECONDS=86400
# Scoring model (lightweight — runs on every unprocessed page)
CAPTURE_SCORING_MODEL=gemini-3-flash-preview
# Extraction model (flagship — runs only on high-scoring pages)
CAPTURE_EXTRACTION_MODEL=gemini-3-flash-preview
# Model for AI-powered process generation from unstructured docs
PROCESS_GENERATION_MODEL=gemini-3-flash-preview
# Vertex AI project and region. If the full VERTEX_CLIENT_* set is provided,
# Gemini uses that service account and targets VERTEX_CLIENT_PROJECT_ID.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
# Optional service account credentials for Vertex AI
LOCAL_ENV=
VERTEX_CLIENT_PROJECT_ID=
VERTEX_CLIENT_PRIVATE_KEY_ID=
VERTEX_CLIENT_PRIVATE_KEY=
VERTEX_CLIENT_EMAIL=
VERTEX_CLIENT_ID=
VERTEX_CLIENT_CERT_URL=

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:8002
VITE_API_URL=http://localhost:8002
VITE_APP_NAME=Koinoflow
VITE_MCP_SERVER_URL=http://localhost:8001

# Email
# Production: set RESEND_API_KEY and leave EMAIL_BACKEND_CLASS unset (defaults to ResendEmailBackend)
# Local dev:  EMAIL_BACKEND_CLASS is overridden in settings/local.py (ConsoleEmailBackend)
# Tests:      set EMAIL_BACKEND_CLASS=apps.common.email_service.SilentEmailBackend
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@example.com
# Per-category sender overrides (optional). Both default to DEFAULT_FROM_EMAIL
# so the simplest setup is to set only DEFAULT_FROM_EMAIL. Override these if
# you want distinct DMARC alignment per email category.
# INVITATION_FROM_EMAIL=invitations@example.com
# ALERTS_FROM_EMAIL=alerts@example.com
# EMAIL_BACKEND_CLASS=apps.common.email_service.ResendEmailBackend

# Billing
# When False (default) the deployment runs in self-hosted mode: no trial
# banner, no trial-expired gate, and new workspaces are not wrapped in a
# Subscription. Set to True for hosted/commercial deployments that run the
# billing flow.
ENABLE_BILLING=False
